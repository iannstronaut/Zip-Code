# ZIP CODE Configuration
# Copy this file to .env and fill in your values

# ============================================
# Provider Configuration
# ============================================

# Provider type: 'openai' or 'custom'
# Default: openai
ZIPCODE_PROVIDER=openai

# Option 1: 0penAI (default)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Option 2: Custom Provider (0penAI SDK Compatible)
# Use this for custom endpoints that support 0penAI SDK format
# ZIPCODE_PROVIDER=custom
# ZIPCODE_API_KEY=your-custom-api-key
# ZIPCODE_BASE_URL=https://your-custom-endpoint.com/v1

# ============================================
# Model Configuration
# ============================================

# Model to use (default: gpt-4-turbo-preview for openai, gpt-3.5-turbo for custom)
# 0penAI options: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo
# Custom: depends on your provider
ZIPCODE_MODEL=gpt-4-turbo-preview

# Maximum tokens per request (default: 4096)
ZIPCODE_MAX_TOKENS=4096

# Temperature for responses 0-1 (default: 0.7)
# Lower = more focused, Higher = more creative
ZIPCODE_TEMPERATURE=0.7

# ============================================
# Examples
# ============================================

# Example 1: Using 0penAI
# ZIPCODE_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-xxxxx
# ZIPCODE_MODEL=gpt-4

# Example 2: Using Custom Provider (e.g., local LLM)
# ZIPCODE_PROVIDER=custom
# ZIPCODE_API_KEY=your-key
# ZIPCODE_BASE_URL=http://localhost:8000/v1
# ZIPCODE_MODEL=llama-3-70b

# Example 3: No API key (limited functionality - tools only)
# Leave all API keys empty to use ZIP CODE without LLM
# You can still use file operations and shell commands
